{
  "permissions": {
    "allow": [
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git branch*)",
      "Bash(git checkout*)",
      "Bash(git push*)",
      "Bash(gh *)",
      "Bash(wc *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(sort *)",
      "Bash(grep *)",
      "Bash(date *)",
      "Bash(echo *)",
      "Bash(chmod *)",
      "Read(*)",
      "Edit(*)",
      "Write(docs/**)",
      "Write(.claude/**)"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Edit(.env*)",
      "Write(.env*)"
    ]
  },
  "env": {
    "STUDIO_DOCS_ROOT": "docs",
    "STUDIO_CHANGES_DIR": "docs/changes",
    "STUDIO_DOMAINS_DIR": "docs/domains"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/validate-change-docs.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/validate-domain-docs.sh"
          }
        ]
      }
    ]
  }
}
